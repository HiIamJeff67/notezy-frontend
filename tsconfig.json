{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "typeRoots": ["./node_modules/@types", "./types"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"],
      "@widgets/*": ["./src/components/widgets/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/components/**/*.tsx",
    "shared/enums/*.enums.ts",
    "src/reducers/*.reducer.ts",
    "shared/types/modeType.typ.ets"
  ],
  "exclude": ["node_modules"]
}
