        <mxCell id="nfp9kuKueZPyxR6_r1Yi-39" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rhombus;whiteSpace=wrap;html=1;" value="waitCount &amp;gt; t" vertex="1">
          <mxGeometry height="80" width="130" x="-30.75" y="680" as="geometry" />
        </mxCell>
        <mxCell id="nfp9kuKueZPyxR6_r1Yi-58" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Merge strategies&lt;/h1&gt;&lt;div&gt;1. updates or moves before deletes&lt;/div&gt;&lt;div&gt;2. create before deletes&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. updates or moves after creates&lt;/div&gt;&lt;div&gt;4.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;multiple creates&lt;/span&gt;&lt;/div&gt;&lt;div&gt;5. multiple updates&lt;/div&gt;&lt;div&gt;6. multiple moves&lt;/div&gt;&lt;div&gt;7. multiple deletes&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="200" x="450" y="510" as="geometry" />
        </mxCell>
        <mxCell id="nfp9kuKueZPyxR6_r1Yi-60" parent="WIyWlLk6GJQsqaUBKTNV-1" style="shape=curlyBracket;whiteSpace=wrap;html=1;rounded=1;flipH=1;labelPosition=right;verticalLabelPosition=middle;align=left;verticalAlign=middle;legacyAnchorPoints=0;" value="" vertex="1">
          <mxGeometry height="250" width="20" x="640" y="224" as="geometry" />
        </mxCell>
        <mxCell id="nfp9kuKueZPyxR6_r1Yi-61" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;strokeColor=none;fillColor=none;html=1;fontSize=24;fontStyle=1;verticalAlign=middle;align=center;" value="Merge" vertex="1">
          <mxGeometry height="40" width="100" x="660" y="329" as="geometry" />
        </mxCell>
        <mxCell id="nfp9kuKueZPyxR6_r1Yi-62" parent="WIyWlLk6GJQsqaUBKTNV-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Algorithm&lt;/h1&gt;&lt;div&gt;Let events = all the events of block with some id&lt;/div&gt;&lt;div&gt;If events.length &amp;lt;= 1: Skip.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. If events[0] == &quot;insert&quot; and events[-1] == &quot;delete&quot;:&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Discard the entire events.&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;2. If (events[0] == &quot;update&quot; or&amp;nbsp; &quot;move&quot;) and events[-1] == &quot;delete&quot;:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Replace events to an array with only one delete event of events[-1].&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. If events[0] !== &quot;delete&quot; and events[-1] !== &quot;delete&quot;:&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;For each update events,&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Merge the blocks of all update events,&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Set the block of events[0] to the block of merged the update event.&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Set the position of events[0] to the position of&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;the last move event.&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Discard all events except for the events[0].&lt;/span&gt;&lt;/div&gt;&lt;div&gt;// now each events of block with some id remains only one.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Classify all the remaining events into 4 groups of inserts, updates, moves, and deletes.&lt;/div&gt;&lt;div&gt;Run InsertBlockGroupsWithBlocks API by passing inserts.&lt;/div&gt;&lt;div&gt;Run UpdateBlocks API by passing updates and moves(update parentBlockId and blockGroupId).&lt;/div&gt;&lt;div&gt;Run DeleteBlocks API by passing deletes.&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="430" x="450" y="680" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
