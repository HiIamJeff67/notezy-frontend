{
  "name": "notezy-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "format:all": "npx @biomejs/biome check --write ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate-local-migrations": "npx drizzle-kit generate --config shared/api/local/drizzle.config.ts",
    "clear-local-migrations": "rm -rf shared/api/local/migrations/**",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "recodegen:mac": "rm -rf src/graphql/generated && npm run codegen",
    "recodegen:win": "rmdir /s /q src/graphql/generated && npm run codegen",
    "licenses:json": "mkdir -p LICENSES && npx license-checker-rseidelsohn --production --json --relativeLicensePath --out LICENSES/third_party_licenses.json",
    "licenses:csv": "mkdir -p LICENSES && npx license-checker-rseidelsohn --production --csv --out LICENSES/third_party_licenses.csv",
    "licenses:json:exclude": "mkdir -p LICENSES && npx license-checker-rseidelsohn --production --json --excludePackages '@notezy/ui;@notezy/core' --out LICENSES/third_party_licenses.json",
    "licenses:collect": "node scripts/getThirdPartyLicenses.mjs",
    "licenses:all": "npm run licenses:json && npm run licenses:collect"
  },
